// WetGreg Hub GATT database — minimal connectable + pairable LE peripheral.
PRIMARY_SERVICE, GAP_SERVICE
CHARACTERISTIC, GAP_DEVICE_NAME, READ, "WetGreg Hub"

PRIMARY_SERVICE, GATT_SERVICE
CHARACTERISTIC, GATT_DATABASE_HASH, READ,

// Device Information Service
PRIMARY_SERVICE, ORG_BLUETOOTH_SERVICE_DEVICE_INFORMATION
CHARACTERISTIC, ORG_BLUETOOTH_CHARACTERISTIC_MANUFACTURER_NAME_STRING, READ, "WetGreg"
CHARACTERISTIC, ORG_BLUETOOTH_CHARACTERISTIC_MODEL_NUMBER_STRING, READ, "Hub"

// WetGreg custom service — phone reads live status, writes a command byte.
PRIMARY_SERVICE, 0000FFE0-0000-1000-8000-00805F9B34FB
// Status: "MOOD STEPS" — readable + notifies on change
CHARACTERISTIC, 0000FFE1-0000-1000-8000-00805F9B34FB, READ | NOTIFY | DYNAMIC,
// Command: phone writes 1 byte (e.g. 'n' = next quote/mood)
CHARACTERISTIC, 0000FFE2-0000-1000-8000-00805F9B34FB, WRITE | WRITE_WITHOUT_RESPONSE | DYNAMIC,
